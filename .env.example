# Monorepo root — copy to `.env` and fill in (all Next apps load from here via `envDir`).
# Dev ports: login 3001, platform 3000, api 3002, capitalstress 3003, capitalhealth 3004,
# incomeengineering 3005, forever 3006.
#
# Capital Health: without Supabase, use http://localhost:3004/preview (dev-only) to view the UI.

# --- Supabase (required for auth / dashboards) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Public app URLs (local dev) ---
NEXT_PUBLIC_LOGIN_APP_URL=http://localhost:3001
NEXT_PUBLIC_PLATFORM_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_APP_URL=http://localhost:3002
NEXT_PUBLIC_MARKETING_SITE_URL=https://thecapitalbridge.com

NEXT_PUBLIC_FOREVER_APP_URL=http://localhost:3006
# Forever header Back defaults to https://platform.thecapitalbridge.com/ — set for local dev:
# NEXT_PUBLIC_FOREVER_BACK_TO_PLATFORM_URL=http://localhost:3000/
NEXT_PUBLIC_INCOME_ENGINEERING_APP_URL=http://localhost:3005
NEXT_PUBLIC_CAPITAL_HEALTH_APP_URL=http://localhost:3004
NEXT_PUBLIC_CAPITAL_STRESS_APP_URL=http://localhost:3003

# Optional: trials / solutions tiles (omit if unused)
# NEXT_PUBLIC_SOLUTIONS_APP_URL=
# NEXT_PUBLIC_TRIAL_FOREVER_APP_URL=
# NEXT_PUBLIC_TRIAL_INCOME_ENGINEERING_APP_URL=
# NEXT_PUBLIC_TRIAL_CAPITAL_HEALTH_APP_URL=

# --- Server-only (login + api routes) ---
API_APP_URL=http://localhost:3002
LOGIN_APP_URL=http://localhost:3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:3002

# Billplz (billing) — leave blank until you test payments
# BILLPLZ_API_KEY=
# BILLPLZ_COLLECTION_ID=
# BILLPLZ_CALLBACK_URL=
# BILLPLZ_X_SIGNATURE_KEY=
# BILLPLZ_REDIRECT_URL=
# BILLPLZ_PAYMENT_FIRST_REDIRECT_URL=

# PAYMENT_RECOVERY_JWT_SECRET=
# BILLING_ADMIN_RECOVERY_SECRET=

# API only: secret used to HMAC-hash client IPs for trial checkout / fingerprinting.
# Generate: openssl rand -base64 48 — set on Vercel for the API project in production.
# TRIAL_CHECKOUT_PEPPER=

# --- Resend (platform Vercel project: strategic_interest admin alert) ---
# Without RESEND_API_KEY + RESEND_FROM, POST /api/strategic-interest still saves the row but does not email.
# RESEND_FROM must use a domain you verified in the Resend dashboard.
# STRATEGIC_INTEREST_ADMIN_EMAIL defaults to admin@thecapitalbridge.com if unset.
# RESEND_API_KEY=re_...
# RESEND_FROM=Capital Bridge <notifications@your-verified-domain.com>
# STRATEGIC_INTEREST_ADMIN_EMAIL=admin@thecapitalbridge.com

# --- Platform admin UI (/admin/login password, /admin/login/strategic, /admin/login/strategic/briefing) ---
# Both are required on production (Vercel advisoryplatform): without either, /admin and /api/admin return 404.
# Comma-separated emails allowed after normal platform sign-in:
# PLATFORM_ADMIN_EMAILS=you@thecapitalbridge.com
# Same order as emails if multiple: one shared password, or one password per admin.
# PLATFORM_ADMIN_PASSWORDS=your-strong-secret
# Optional: fixed signing key for the admin gate cookie (else derived from passwords + email list).
# PLATFORM_ADMIN_GATE_SECRET=

# --- Feature flags ---
# NEXT_PUBLIC_USE_V2=0
# NEXT_PUBLIC_ENV=staging

# --- Staging platform (https://staging.thecapitalbridge.com) — @cb/platform Preview deployment ---
# Host-based gate + ribbon: production hostnames are unaffected.
# STAGING_GATE_PASSWORD=choose-a-long-random-secret
# Optional separate HMAC secret for the staging cookie (defaults to STAGING_GATE_PASSWORD):
# STAGING_GATE_SIGNING_SECRET=
# Canonical staging origin (hostname used for gate match if not a blocked production host):
# NEXT_PUBLIC_APP_URL=https://staging.thecapitalbridge.com
# Human-readable label only — gate still requires hostname match (do not rely on this alone):
# NEXT_PUBLIC_APP_ENV=staging
# Isolate Supabase cookies to this host only (recommended for staging; avoids sharing auth with *.thecapitalbridge.com):
# NEXT_PUBLIC_CB_AUTH_COOKIE_SCOPE=host
# Override staging hostname for tests (default staging.thecapitalbridge.com):
# NEXT_PUBLIC_CB_STAGING_HOSTNAME=staging.thecapitalbridge.com
